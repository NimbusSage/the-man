# Host port mappings for docker-compose
# Change these if the default ports are already bound on the host.
# Docker Compose reads this file automatically from the project root.
#
#   cp .env.example .env
#
# Set a strong JWT secret for production:
#   openssl rand -base64 48
# JWT_SECRET=

# Set a strong postgres password:
# POSTGRES_PASSWORD=

# Comma-separated list of allowed CORS origins, or "true" to reflect the
# request origin (safe when nginx proxies everything on the same port).
# CORS_ORIGINS=true

HOST_POSTGRES_PORT=5432
HOST_REDIS_PORT=6379
HOST_BACKEND_PORT=3000
HOST_WEB_PORT=80
HOST_PROMETHEUS_PORT=9090
HOST_GRAFANA_PORT=3001

# For production behind a domain, set the API URL so the frontend bakes it in
# (leave empty to use relative URLs, which works when nginx proxies /api/):
# VITE_API_URL=https://monitor.your-company.com
